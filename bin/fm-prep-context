#!/usr/bin/env bash
# fm-prep-context — gather context for crewmate before spawn.
# Pure bash. No model. No decomposition. No ambiguity.
# Always runs the same pipeline: structure → search → git → package.
#
# Usage: fm-prep-context "fix token validation" [file.go] [file2.go]
set -euo pipefail

TASK="${1:-}"
shift 2>/dev/null || true
FILES=("$@")

# ── Package header ─────────────────────────────────────────────────
output="## Context"
output+=$'\n\n'
output+="**Task:** $TASK"
output+=$'\n\n'

# ── 1. GIT: what changed recently ──────────────────────────────────
output+="### Recent changes"
output+=$'\n'
output+='```'
output+=$'\n'
output+="$(git log --oneline -5 2>/dev/null || echo 'no git history')"
output+=$'\n'
output+='```'
output+=$'\n\n'

# ── 2. GIT: any uncommitted work ───────────────────────────────────
dirty=$(git status --porcelain 2>/dev/null | head -20)
if [ -n "$dirty" ]; then
  output+="### Uncommitted changes"
  output+=$'\n'
  output+='```'
  output+=$'\n'
  output+="$dirty"
  output+=$'\n'
  output+='```'
  output+=$'\n\n'
fi

# ── 3. FILES: structure + hot lines ────────────────────────────────
if [ ${#FILES[@]} -gt 0 ]; then
  output+="### Files"
  output+=$'\n\n'
  for f in "${FILES[@]}"; do
    resolved=$(find . -path "*/$f" -not -path '*/.git/*' 2>/dev/null | head -1)
    [ -z "$resolved" ] && resolved="$f"
    if [ -f "$resolved" ]; then
      lines=$(wc -l < "$resolved" | tr -d ' ')
      output+="**$(basename "$resolved")** ($lines lines)"
      output+=$'\n'
      # Structure via tldr
      struct=$(tldr structure "$resolved" 2>/dev/null | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    for fi in d.get('files', []):
        for defn in fi.get('definitions', []):
            k = defn.get('kind', '?')
            n = defn.get('name', '?')
            ls = defn.get('line_start', '?')
            le = defn.get('line_end', '?')
            sig = defn.get('signature', '')[:100]
            print(f'  {k:8s} {n:25s} L{ls}-{le}  {sig}')
except: pass
" 2>/dev/null || echo "  (structure unavailable)")

      if [ -n "$struct" ]; then
        output+='```'
        output+=$'\n'
        output+="$struct"
        output+=$'\n'
        output+='```'
        output+=$'\n'
      fi

      # Hot lines: extract key terms from task, grep the file
      terms=$(echo "$TASK" | tr -cs '[:alnum:]' '\n' | grep -viE '^(a|an|the|is|in|it|of|to|and|or|be|do|we|no|so|if|at|on|by|as|he|she|me|my|for|fix|add|the|that|this|with|from|when|how|what|where|which|who|why|can|will|should|could|would|does|has|had|not|but|all|are|was|were|need|want|get|got)$' | sort -u | head -8 | tr '\n' '|' | sed 's/|$//')
      if [ -n "$terms" ]; then
        matches=$(rg -n "$terms" "$resolved" 2>/dev/null | head -15)
        if [ -n "$matches" ]; then
          output+="*Matching lines:*"
          output+=$'\n'
          output+='```'
          output+=$'\n'
          output+="$matches"
          output+=$'\n'
          output+='```'
          output+=$'\n'
        fi
      fi
      output+=$'\n'
    fi
  done
fi

# ── 4. SEMANTIC: cocoindex search ──────────────────────────────────
if command -v ccc >/dev/null 2>&1; then
  sem=$(ccc search "$TASK" 2>/dev/null | head -8)
  if [ -n "$sem" ] && [ "$sem" != "(index not available)" ]; then
    output+="### Semantic matches (cocoindex)"
    output+=$'\n'
    output+='```'
    output+=$'\n'
    output+="$sem"
    output+=$'\n'
    output+='```'
    output+=$'\n\n'
  fi
fi

# ── 5. EXTERNAL: githits example (if file references a known package) ──
if command -v githits >/dev/null 2>&1; then
  pkg=$(echo "$TASK" | rg -o 'npm:[a-zA-Z@._-]+|pypi:[a-zA-Z._-]+|go:[a-zA-Z._/-]+' 2>/dev/null | head -1)
  if [ -n "$pkg" ]; then
    ext=$(githits example "$TASK" 2>/dev/null | head -20)
    if [ -n "$ext" ]; then
      output+="### External examples (githits)"
      output+=$'\n'
      output+='```'
      output+=$'\n'
      output+="$ext"
      output+=$'\n'
      output+='```'
      output+=$'\n\n'
    fi
  fi
fi

# ── 6. TESTS: if task mentions test/validate/check ──────────────────
if echo "$TASK" | grep -qi 'test\|validate\|check\|verify\|pass\|fail'; then
  if [ -f "Makefile" ]; then
    test_result=$(make test 2>&1 | tail -15)
    if [ -n "$test_result" ]; then
      output+="### Test results"
      output+=$'\n'
      output+='```'
      output+=$'\n'
      output+="$test_result"
      output+=$'\n'
      output+='```'
      output+=$'\n\n'
    fi
  fi
fi

# ── Cap at ~800 tokens ─────────────────────────────────────────────
echo "$output" | head -250
