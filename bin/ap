#!/usr/bin/env bash
set -euo pipefail

AP_LOG="$HOME/.applypilot/ap.log"
AP_LOCK="$HOME/.applypilot/ap.lock"
mkdir -p "$HOME/.applypilot"

# Single-instance: only one ap process may run at a time.
# flock is kernel-released on crash/exit — no stale lock risk.
exec {fd}>"$AP_LOCK"
if ! flock -n "$fd"; then
  echo "ap: another applypilot process is already running (lock held on $AP_LOCK)" | tee -a "$AP_LOG" >&2
  exit 1
fi

# Fetch TokenRouter API Key from Bridge Secrets Keychain
tokenrouter_api_key="$(security find-generic-password -a TOKENROUTER_API_KEY -s bridge-secrets -w)" || {
  echo "ap: TOKENROUTER_API_KEY is missing from the bridge-secrets Keychain service; run 'bridge secrets refresh'" | tee -a "$AP_LOG" >&2
  exit 1
}

if [ -z "$tokenrouter_api_key" ]; then
  echo "ap: TOKENROUTER_API_KEY is empty in the bridge-secrets Keychain service; run 'bridge secrets refresh'" | tee -a "$AP_LOG" >&2
  exit 1
fi

# Activate virtual environment
source "$HOME/projects/ApplyPilot/venv/bin/activate"

# Inject secrets securely in-memory and execute applypilot
# CHROME_PATH: Chrome is the automation browser — Brave is the captain's personal browser.
# Worker profiles are isolated in ~/.applypilot/chrome-workers/ per session.
# All stderr captured to ap.log for crash debugging.
echo "[$(date -Iseconds)] ap $*" >> "$AP_LOG"
exec env \
  LLM_API_KEY="$tokenrouter_api_key" \
  LLM_URL="https://api.tokenrouter.com/v1" \
  LLM_MODEL="deepseek/deepseek-v4-pro" \
  CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
  applypilot "$@" 2>>"$AP_LOG"
