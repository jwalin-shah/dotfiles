#!/usr/bin/env bash
set -euo pipefail

tokenrouter_api_key="$(security find-generic-password -a TOKENROUTER_API_KEY -s bridge-secrets -w)" || {
  echo "ct: TOKENROUTER_API_KEY is missing from the bridge-secrets Keychain service; run 'bridge secrets refresh'" >&2
  exit 1
}
if [ -z "$tokenrouter_api_key" ]; then
  echo "ct: TOKENROUTER_API_KEY is empty in the bridge-secrets Keychain service; run 'bridge secrets refresh'" >&2
  exit 1
fi

exec env \
  CLAUDE_CONFIG_DIR="$HOME/.claude-token" \
  ANTHROPIC_API_KEY="$tokenrouter_api_key" \
  ANTHROPIC_BASE_URL="https://api.tokenrouter.com" \
  ANTHROPIC_DEFAULT_OPUS_MODEL="deepseek/deepseek-v4-pro" \
  ANTHROPIC_DEFAULT_OPUS_MODEL_SUPPORTED_CAPABILITIES="effort,xhigh_effort,max_effort" \
  ANTHROPIC_DEFAULT_SONNET_MODEL="deepseek/deepseek-v4-flash" \
  ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTED_CAPABILITIES="effort,xhigh_effort,max_effort" \
  ANTHROPIC_DEFAULT_HAIKU_MODEL="moonshotai/kimi-k2.7-code" \
  ANTHROPIC_DEFAULT_HAIKU_MODEL_SUPPORTED_CAPABILITIES="effort,xhigh_effort" \
  ANTHROPIC_DEFAULT_FABLE_MODEL="MiniMax-M3" \
  ANTHROPIC_DEFAULT_FABLE_MODEL_SUPPORTED_CAPABILITIES="effort,xhigh_effort,max_effort" \
  ANTHROPIC_CUSTOM_MODEL_OPTION="z-ai/glm-5.2" \
  ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES="effort,xhigh_effort,max_effort" \
  /opt/homebrew/bin/claude --dangerously-skip-permissions "$@"
