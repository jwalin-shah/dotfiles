#!/usr/bin/env bash
# config-lint — validates that documented configuration matches reality.
# Every launcher in AGENTS.md must exist on disk. Every launcher on disk
# must be documented in AGENTS.md. No dead entries.
set -euo pipefail

HERE=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)
AGENTS_MD="$HERE/../home/AGENTS.md"
BIN_DIR="$HOME/bin"
fails=0
ok()   { printf 'ok - %s\n' "$1"; }
bad()  { printf 'not ok - %s\n' "$1" >&2; fails=$((fails + 1)); }

# Extract launcher commands from the Launchers table in AGENTS.md.
documented=$(sed -n '/^## Launchers/,/^## /p' "$AGENTS_MD" | \
    grep -oE '^\| `[a-z]+` \|' | sed 's/^| `//;s/` |$//')

# Check every documented launcher exists on disk.
for cmd in $documented; do
    if [ ! -x "$BIN_DIR/$cmd" ]; then
        bad "launcher '$cmd' listed in AGENTS.md but $BIN_DIR/$cmd does not exist or is not executable"
    else
        ok "launcher '$cmd' exists and is executable"
    fi
done

# Check every launcher in ~/bin is documented.
# Skip: backup files, directories, bridge adapter scripts, utility/automation scripts.
# These are NOT launchers — they don't exec an LLM tool.
for bin in "$BIN_DIR"/*; do
    [ -x "$bin" ] || [ -d "$bin" ] && continue  # skip non-executable files and dirs
    [ -f "$bin" ] || continue
    name=$(basename "$bin")

    # Skip patterns (non-launcher categories).
    case "$name" in
        *.backup)         continue ;;  # backup files
        *-bridge|*-backup|*-axi) continue ;;  # bridge wrappers, backups, automation wrappers
        audit-*)          continue ;;  # audit scripts
        brave-*)          continue ;;  # browser automation
        chatgpt-bridge|gemini-bridge|perplexity-bridge) continue ;;  # research bridges
        claude|com|ctx7)  continue ;;  # bare command wrappers
        cursor-login|jw-*|openwiki|auto-save.sh) continue ;;  # utility scripts
        backends|test-adapter|config-lint) continue ;;  # infrastructure
    esac

    # Check if this name appears in the documented list.
    found=0
    for d in $documented; do
        [ "$name" = "$d" ] && found=1 && break
    done
    [ "$found" -eq 1 ] && continue

    bad "launcher '$name' exists in $BIN_DIR but is not documented in AGENTS.md Launchers table"
done

if [ "$fails" -eq 0 ]; then
    echo "config-lint: launcher checks passed"
else
    echo "config-lint: $fails launcher failure(s)" >&2
    exit 1
fi

# ── Daemon contract enforcement ──────────────────────────────────────
# Every LaunchAgent in configuration.nix that uses daemon-wrapper must
# satisfy the daemon contract invariants.
CONFIG_NIX="$HERE/../configuration.nix"
[ -f "$CONFIG_NIX" ] || { echo "config-lint: cannot find configuration.nix at $CONFIG_NIX" >&2; exit 1; }

# Check 1: No old wrapper scripts referenced
echo "=== daemon contract: no old wrappers ==="
for old_wrapper in cognee-daemon.sh cocoindex-daemon.sh tldr-daemon.sh mlx-chat-daemon.sh; do
    if grep -q "$old_wrapper" "$CONFIG_NIX"; then
        bad "daemon contract: $old_wrapper found in configuration.nix — use daemon-wrapper instead"
    else
        ok "daemon contract: $old_wrapper not used in configuration.nix"
    fi
done

# Check 2: daemon-wrapper references have required env vars
echo "=== daemon contract: required env vars ==="
REQUIRED_VARS="DAEMON_NAME DAEMON_PORT DAEMON_DISPLAY_NAME DAEMON_TYPE DAEMON_HEALTH_URL"
# Find all daemon-wrapper blocks and check env vars are set
DAEMON_COUNT=$(grep -c 'daemon-wrapper' "$CONFIG_NIX" || echo 0)
# Exclude comment lines
COMMENT_COUNT=$(grep -c '^[[:space:]]*#.*daemon-wrapper' "$CONFIG_NIX" || echo 0)
DAEMON_COUNT=$((DAEMON_COUNT - COMMENT_COUNT))
echo "  daemon-wrapper references: $DAEMON_COUNT"

# Extract the sections between daemon-wrapper and the next closing of EnvironmentVariables
# This is approximate — a full parser would be better, but this catches obvious misses.
for var in $REQUIRED_VARS; do
    var_lines=$(grep -c "$var" "$CONFIG_NIX" || echo 0)
    if [ "$var_lines" -ge "$DAEMON_COUNT" ]; then
        ok "daemon contract: $var present ($var_lines occurrences for $DAEMON_COUNT daemon-wrapper refs)"
    else
        bad "daemon contract: $var appears $var_lines times but $DAEMON_COUNT daemon-wrapper references — some service may be missing it"
    fi
done

# Check 3: KeepAlive.SuccessfulExit used, not bare KeepAlive (for daemon-wrapper services)
echo "=== daemon contract: KeepAlive.SuccessfulExit ==="
# Find lines after daemon-wrapper that have KeepAlive
if grep -A15 'daemon-wrapper' "$CONFIG_NIX" | grep -q 'KeepAlive = true'; then
    bad "daemon contract: bare KeepAlive = true found near daemon-wrapper — use KeepAlive.SuccessfulExit = false"
else
    ok "daemon contract: no bare KeepAlive near daemon-wrapper"
fi

if [ "$fails" -eq 0 ]; then
    echo "config-lint: all checks passed"
else
    echo "config-lint: $fails failure(s)" >&2
    exit 1
fi
