#!/usr/bin/env bash
# jw-init — bootstrap a fresh repo with skills + docs + cocoindex.
# Run once per project. Idempotent — safe to re-run.
#
# Usage: jw-init [repo-path]
#   Without args: runs on current directory.
#   With args:    runs on specified repo path.
set -euo pipefail

REPO="${1:-$PWD}"
cd "$REPO"

NAME=$(basename "$PWD")
REMOTE=$(git remote get-url origin 2>/dev/null || echo "none")
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
AGENT_FILE=""

echo "=== jw-init: $NAME ==="
echo "  remote: $REMOTE"
echo "  branch: $BRANCH"

# ── Step 1: docs/agents/ — Matt Pocock skills config ──────────────
AGENTS_DIR="docs/agents"
mkdir -p "$AGENTS_DIR"

# Issue tracker: always GitHub for your repos
if [ ! -f "$AGENTS_DIR/issue-tracker.md" ]; then
  echo "  + $AGENTS_DIR/issue-tracker.md"
  cat > "$AGENTS_DIR/issue-tracker.md" << 'EOF'
# Issue tracker: GitHub

Issues and PRDs for this repo live as GitHub issues. Use the `gh` CLI.

- Create: `gh issue create --title "..." --body "..."`
- Read:   `gh issue view <number> --comments`
- List:   `gh issue list --state open --json number,title,body,labels`
- Close:  `gh issue close <number> --comment "..."`
- Labels: `gh issue edit <number> --add-label "..."` / `--remove-label "..."`

Infer the repo from `git remote -v` — `gh` does this automatically.
EOF
fi

# Triage labels: always defaults
if [ ! -f "$AGENTS_DIR/triage-labels.md" ]; then
  echo "  + $AGENTS_DIR/triage-labels.md"
  cat > "$AGENTS_DIR/triage-labels.md" << 'EOF'
# Triage Labels

| Canonical role        | Label string        | Meaning                                  |
|-----------------------|---------------------|------------------------------------------|
| `needs-triage`        | `needs-triage`      | Maintainer needs to evaluate             |
| `needs-info`          | `needs-info`        | Waiting on reporter                      |
| `ready-for-agent`     | `ready-for-agent`   | Ready for an AFK agent, no human context |
| `ready-for-human`     | `ready-for-human`   | Requires human implementation            |
| `wontfix`             | `wontfix`           | Will not be actioned                     |

Skills use these labels when creating/triaging issues.
EOF
fi

# Domain docs: always single-context
if [ ! -f "$AGENTS_DIR/domain.md" ]; then
  echo "  + $AGENTS_DIR/domain.md"
  cat > "$AGENTS_DIR/domain.md" << 'EOF'
# Domain Docs

This is a **single-context** repo. Skills read from:

- `CONTEXT.md` at the repo root for domain glossary.
- `docs/adr/` for architectural decisions.

If a skill searches for a concept not in the glossary, note it — `/grill-with-docs`
creates CONTEXT.md lazily when terms need resolution.
EOF
fi

# ── Step 2: Agent skills block ────────────────────────────────────
# Find the file to edit: CLAUDE.md > AGENTS.md > neither
if [ -f "CLAUDE.md" ]; then
  AGENT_FILE="CLAUDE.md"
elif [ -f "AGENTS.md" ]; then
  AGENT_FILE="AGENTS.md"
fi

SKILLS_BLOCK='## Agent skills

### Issue tracker

GitHub issues. See `docs/agents/issue-tracker.md`.

### Triage labels

Default Matt Pocock vocabulary. See `docs/agents/triage-labels.md`.

### Domain docs

Single-context layout. See `docs/agents/domain.md`.'

if [ -n "$AGENT_FILE" ]; then
  if grep -q '## Agent skills' "$AGENT_FILE" 2>/dev/null; then
    echo "  ✓ $AGENT_FILE — Agent skills block already exists"
  else
    echo "  + $AGENT_FILE — adding Agent skills block"
    echo "" >> "$AGENT_FILE"
    echo "$SKILLS_BLOCK" >> "$AGENT_FILE"
  fi
else
  echo "  + AGENTS.md — creating with Agent skills block"
  cat > "AGENTS.md" << EOF
# $NAME

$SKILLS_BLOCK
EOF
fi

# ── Step 3: cocoindex include path ────────────────────────────────
COCOINDEX_CFG="$HOME/.cocoindex_code/settings.yml"
if [ -f "$COCOINDEX_CFG" ]; then
  if python3 -c "
import yaml
with open('$COCOINDEX_CFG') as f:
    s = yaml.safe_load(f)
if '$PWD' not in s.get('include_paths', []):
    s.setdefault('include_paths', []).append('$PWD')
    with open('$COCOINDEX_CFG', 'w') as f:
        yaml.dump(s, f, default_flow_style=False, sort_keys=False)
    print('added')
else:
    print('exists')
" 2>/dev/null | grep -q 'added'; then
    echo "  + cocoindex — added $PWD to include_paths"
    if ccc daemon restart 2>/dev/null; then
      echo "  ✓ cocoindex daemon restarted"
    fi
  else
    echo "  ✓ cocoindex — already tracked"
  fi
fi

# ── Step 4: Firstmate project registry ────────────────────────────
FM_PROJECTS="$HOME/firstmate/projects"
if [ -d "$FM_PROJECTS" ]; then
  if [ ! -e "$FM_PROJECTS/$NAME" ] && [ ! -e "$FM_PROJECTS/$NAME.git" ]; then
    echo "$PWD" > "$FM_PROJECTS/$NAME"
    echo "  + firstmate — registered in projects/$NAME"
  else
    echo "  ✓ firstmate — already registered"
  fi
fi

# ── Step 5: openwiki (fully automated) ────────────────────────────
if [ ! -f ".openwiki/state.json" ] 2>/dev/null; then
  echo "  → openwiki — generating initial documentation..."
  openwiki --init -p "Generate comprehensive documentation for $NAME. This is a code project hosted at $REMOTE on branch $BRANCH. Document the architecture, key modules, build system, dependencies, and how to contribute." 2>&1 | tail -3
  echo "  ✓ openwiki — initial docs generated"
else
  echo "  ✓ openwiki — docs already exist"
fi

echo
echo "=== Done: $NAME ==="
echo "  Skills:  ✓ /to-issues /triage /to-prd /diagnose /tdd /grill-with-docs /improve-codebase-architecture"
echo "  Index:   ✓ ccc search \"<query>\""
echo "  Openwiki:  run 'openwiki' when you want docs"
echo "  Rebuild:   ./rebuild.sh (to apply LaunchAgent changes)"
