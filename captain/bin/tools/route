#!/usr/bin/env bash
# route — Quota-aware routing.
# Tells you which launch profile to use for each tool based on quota state.
#
# Usage:
#   route                          # Show full routing table
#   route --for claude             # Show routing for Claude Code
#   route --profile claude         # Print just the profile name ("a" or "token")
#   route --profile codex          # Print "cx" or "token"
#   route --profile agy            # Print "agy" or "token"
#   route --rankings               # Show urgency rankings
#
# For scripting (crewmate launchers use this):
#   PROFILE=$(route --profile claude)   # → "a" or "token"
#   claude-wrapper "$@"                 # if "a", ct-wrapper if "token"

set -euo pipefail

ROUTER="$HOME/projects/quota-core/src/quota_router.py"
QUOTA_BIN="$HOME/.local/bin/quota"

[ -f "$ROUTER" ] || { echo "route: quota_router.py not found at $ROUTER" >&2; exit 1; }
[ -x "$QUOTA_BIN" ] || { echo "route: '$QUOTA_BIN' not found — build quota-core" >&2; exit 1; }

exec python3 "$ROUTER" "$@"
