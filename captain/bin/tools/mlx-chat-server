#!/usr/bin/env bash
# Wrapper called by com.jwalinshah.mlx-chat-server LaunchAgent.
# Sources ~/.config/jw/models.env so the plist never needs a hardcoded model path.
# To switch models: edit JW_CHAT_MODEL_REPO in ~/.config/jw/models.env and
#   launchctl kickstart -k gui/$(id -u)/com.jwalinshah.mlx-chat-server

set -euo pipefail
source "${HOME}/.config/jw/models.env"

exec /Users/jwalinshah/.local/share/uv/tools/mlx-lm/bin/mlx_lm.server \
  --model "${JW_CHAT_MODEL_REPO}" \
  --host 127.0.0.1 \
  --port 8080 \
  --max-tokens "${JW_CHAT_MAX_TOKENS}" \
  --trust-remote-code
