#!/usr/bin/env bash
# chrome-devtools-axi with Brave — ensures Brave automation profile is running
# with remote debugging before running AXI commands.
set -euo pipefail

# Check if Brave automation is running on port 9222
if ! curl -sf http://127.0.0.1:9222/json/version >/dev/null 2>&1; then
  echo "Starting Brave automation profile..." >&2
  ~/bin/brave-automation
  sleep 2
fi

CHROME_DEVTOOLS_AXI_BROWSER_URL="http://127.0.0.1:9222" chrome-devtools-axi "$@"
