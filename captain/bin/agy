#!/usr/bin/env python3
"""Gemini via Google API - WITH AUTOMATIC COMPRESSION HOOKS"""
import subprocess
import sys
import os
from pathlib import Path

# Resolve the actual path (handle symlinks)
script_path = Path(os.path.realpath(__file__))
wrapper = script_path.parent / "agy-wrapper"
os.execvp(str(wrapper), [str(wrapper)] + sys.argv[1:])
