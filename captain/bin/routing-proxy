#!/opt/homebrew/bin/python3
"""routing-proxy — Quota-aware proxy for TokenRouter + subscription routing.

Replaces tokenrouter-proxy. Forwards requests to api.tokenrouter.com but also:
- Exposes /v1/route endpoint with quota-aware routing recommendations
- Logs which subscription backend would be optimal for each request
- Falls back to TokenRouter for all actual forwarding

Usage:
    routing-proxy                    # start (port 18999, foreground)
    routing-proxy --daemon           # start as background daemon
    routing-proxy --stop             # stop the daemon
    routing-proxy --status           # check if running
"""
import os
import sys
import signal
import socket
import ssl
import json
import time
import threading

# Add quota-core src to path
ROUTER_PATH = os.path.expanduser("~/projects/quota-core/src")
if ROUTER_PATH not in sys.path:
    sys.path.insert(0, ROUTER_PATH)

PIDFILE = os.path.expanduser("~/.local/share/jw/tokenrouter-proxy.pid")
LOGFILE = os.path.expanduser("~/.local/share/jw/tokenrouter-proxy.log")
KEYFILE = os.path.expanduser("~/.local/share/jw/tokenrouter-proxy.key")
PORT = 18999
UPSTREAM = ("api.tokenrouter.com", 443)

# ─── Quota router (lazy-loaded) ────────────────────────────────────────────

_quota_router = None
_quota_lock = threading.Lock()
_quota_last_fetch = 0.0
_quota_cache_ttl = 30.0
_quota_cached_rankings = []
_quota_cached_decisions = {}
_quota_error = None


def _get_quota_router():
    """Lazy-import and cache QuotaRouter."""
    global _quota_router
    if _quota_router is not None:
        return _quota_router
    try:
        from quota_router import QuotaRouter
        _quota_router = QuotaRouter
        return _quota_router
    except ImportError as e:
        log(f"quota_router not available: {e}")
        return None


def refresh_quota_cache():
    """Refresh cached routing decisions (called from background thread)."""
    global _quota_cached_rankings, _quota_cached_decisions, _quota_error, _quota_last_fetch

    now = time.time()
    if now - _quota_last_fetch < _quota_cache_ttl:
        return

    RouterCls = _get_quota_router()
    if RouterCls is None:
        return

    with _quota_lock:
        try:
            router = RouterCls()
            router._cache_ttl = _quota_cache_ttl
            decisions = router.route_all()
            rankings = router.get_provider_rankings()
            _quota_cached_decisions = {k: v.to_dict() for k, v in decisions.items()}
            _quota_cached_rankings = rankings
            _quota_error = None
            _quota_last_fetch = time.time()
        except Exception as e:
            _quota_error = str(e)
            log(f"quota refresh error: {e}")


def get_routing_info():
    """Get current routing state as a dict."""
    refresh_quota_cache()
    with _quota_lock:
        return {
            "cached": _quota_cached_decisions,
            "rankings": _quota_cached_rankings,
            "error": _quota_error,
            "last_fetch": _quota_last_fetch,
        }


# ─── Background quota refresher ────────────────────────────────────────────

def quota_refresh_loop():
    """Periodically refresh quota cache in background."""
    while True:
        refresh_quota_cache()
        time.sleep(_quota_cache_ttl)


# ─── Logging ───────────────────────────────────────────────────────────────

COMPONENT = "routing-proxy"


def log(msg):
    ts = time.strftime("%Y-%m-%dT%H:%M:%S")
    line = f"[{ts}] [{COMPONENT}] {msg}\n"
    with open(LOGFILE, "a") as f:
        f.write(line)


# ─── HTTP utilities ────────────────────────────────────────────────────────

def build_response(status_line, headers, body=b""):
    """Build an HTTP response bytes."""
    resp = status_line.encode() + b"\r\n"
    for k, v in headers.items():
        resp += f"{k}: {v}\r\n".encode()
    resp += b"\r\n"
    if body:
        resp += body
    return resp


def json_response(data, status="200 OK"):
    body = json.dumps(data).encode("utf-8")
    return build_response(
        f"HTTP/1.1 {status}",
        {
            "Content-Type": "application/json; charset=utf-8",
            "Content-Length": str(len(body)),
            "Access-Control-Allow-Origin": "*",
            "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
            "Access-Control-Allow-Headers": "*",
        },
        body,
    )


# ─── Request parsing ───────────────────────────────────────────────────────

def recv_http_request(client_sock):
    """Read full HTTP request from socket. Returns (raw_data, method, path, headers, body)."""
    data = b""
    while True:
        chunk = client_sock.recv(65536)
        if not chunk:
            break
        data += chunk
        if b"\r\n\r\n" in data:
            header_end = data.index(b"\r\n\r\n") + 4
            headers_raw = data[:header_end].decode("utf-8", errors="replace")
            clen = 0
            for line in headers_raw.split("\r\n"):
                low = line.lower()
                if low.startswith("content-length:"):
                    clen = int(line.split(":")[1].strip())
            body_len = len(data) - header_end
            if clen > 0 and body_len < clen:
                needed = clen - body_len
                more = client_sock.recv(needed)
                data += more
            break
    return data


def parse_request(data):
    """Parse raw HTTP request bytes."""
    if not data:
        return None, None, None, {}, b""
    first_line = data.split(b"\r\n")[0].decode()
    parts = first_line.split()
    method = parts[0] if len(parts) > 0 else "GET"
    path = parts[1] if len(parts) > 1 else "/"
    header_end = data.index(b"\r\n\r\n") + 4
    raw = data[:header_end].decode("utf-8", errors="replace")
    headers = {}
    for line in raw.strip("\r\n").split("\r\n")[1:]:
        if ":" in line:
            k, v = line.split(":", 1)
            headers[k.strip().lower()] = v.strip()
    body = data[header_end:]
    return method, path, headers, body


# ─── Route endpoint ────────────────────────────────────────────────────────

def handle_route_request(path, method):
    """Handle /v1/route and related endpoints."""
    if path == "/v1/route" and method in ("GET", "OPTIONS"):
        if method == "OPTIONS":
            return build_response(
                "HTTP/1.1 204 No Content",
                {
                    "Access-Control-Allow-Origin": "*",
                    "Access-Control-Allow-Methods": "GET, OPTIONS",
                    "Access-Control-Allow-Headers": "*",
                },
            )

        refresh_quota_cache()
        with _quota_lock:
            return json_response({
                "service": COMPONENT,
                "version": "1.0",
                "routing": _quota_cached_decisions,
                "rankings": _quota_cached_rankings,
                "quota_error": _quota_error,
                "freshness_seconds": time.time() - _quota_last_fetch if _quota_last_fetch else -1,
            })

    if path.startswith("/v1/route/") and method == "GET":
        model = path[len("/v1/route/"):]
        if not model:
            return json_response({"error": "no model specified"}, "400 Bad Request")

        # Check cache first
        refresh_quota_cache()
        with _quota_lock:
            if model in _quota_cached_decisions:
                return json_response(_quota_cached_decisions[model])

        # Fall back to fresh routing
        RouterCls = _get_quota_router()
        if RouterCls is None:
            return json_response({"error": "router not available"}, "503 Service Unavailable")

        try:
            router = RouterCls()
            router._cache_ttl = 300  # use long cache to avoid repeated subprocess calls
            decision = router.route(model)
            return json_response(decision.to_dict())
        except Exception as e:
            return json_response({"error": str(e)}, "500 Internal Server Error")

    return None


# ─── Client handler ─────────────────────────────────────────────────────────

def handle_client(client_sock):
    try:
        data = recv_http_request(client_sock)
    except Exception as e:
        log(f"Read error: {e}")
        client_sock.close()
        return

    if not data:
        client_sock.close()
        return

    method, path, req_headers, body = parse_request(data)
    if method is None:
        client_sock.close()
        return

    # ─── Route endpoint ──────────────────────────────────────────────────
    if path.startswith("/v1/route") or path == "/route":
        resp = handle_route_request(path, method)
        if resp:
            client_sock.sendall(resp)
            client_sock.close()
            return

    # ─── Health check ────────────────────────────────────────────────────
    if method == "HEAD" and path in ("/", "/v1/models"):
        client_sock.sendall(b"HTTP/1.1 200 OK\r\nContent-Length: 0\r\n\r\n")
        client_sock.close()
        return

    if method == "GET" and path == "/health":
        info = get_routing_info()
        resp = json_response({
            "status": "ok",
            "service": COMPONENT,
            "quota_error": info["error"],
        })
        client_sock.sendall(resp)
        client_sock.close()
        return

    # ─── Quota-aware routing hint ────────────────────────────────────────
    # For message requests, log the optimal routing recommendation
    if path == "/v1/messages" and method == "POST" and body:
        try:
            req_json = json.loads(body)
            model = req_json.get("model", "unknown")
            # Get routing recommendation
            RouterCls = _get_quota_router()
            if RouterCls:
                router = RouterCls()
                try:
                    decision = router.route(model)
                    log(f"ROUTE {model} → optimal: {decision.provider_key} ({decision.provider_label}) [{decision.reason}]")
                except Exception as e:
                    log(f"ROUTE {model} → error: {e}")
        except (json.JSONDecodeError, Exception) as e:
            log(f"ROUTE parse error: {e}")

    # ─── Get API key and forward ─────────────────────────────────────────
    real_key = get_real_key()
    if not real_key:
        log("ERROR: Could not resolve TOKENROUTER_API_KEY")
        resp = json_response({"error": "missing_api_key"}, "502 Bad Gateway")
        client_sock.sendall(resp)
        client_sock.close()
        return

    # Rebuild request with real auth
    header_end = data.index(b"\r\n\r\n") + 4
    raw = data[:header_end].decode("utf-8", errors="replace")
    header_lines = raw.strip("\r\n").split("\r\n")
    request_line = header_lines[0]
    new_headers_lines = []
    for line in header_lines[1:]:
        if not line:
            continue
        low = line.lower()
        if low.startswith("x-api-key:") or low.startswith("authorization:"):
            continue
        if low.startswith("host:"):
            new_headers_lines.append(f"Host: {UPSTREAM[0]}")
        else:
            new_headers_lines.append(line)

    new_headers_lines.append(f"Authorization: Bearer {real_key}")

    request = request_line + "\r\n" + "\r\n".join(new_headers_lines) + "\r\n\r\n"
    request_bytes = request.encode("utf-8") + body

    log(f"{method} {path} → forwarding (key: {real_key[:10]}...)")

    # Forward to TokenRouter
    try:
        remote = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        remote.settimeout(30)
        remote.connect(UPSTREAM)
        context = ssl.create_default_context()
        remote_ssl = context.wrap_socket(remote, server_hostname=UPSTREAM[0])
        remote_ssl.sendall(request_bytes)

        # Receive response
        response = b""
        remote_ssl.settimeout(120)
        try:
            while b"\r\n\r\n" not in response:
                chunk = remote_ssl.recv(65536)
                if not chunk:
                    break
                response += chunk

            if b"\r\n\r\n" not in response:
                log("No headers received from upstream")
                client_sock.sendall(response)
                client_sock.close()
                remote_ssl.close()
                return

            header_end = response.index(b"\r\n\r\n") + 4
            headers_raw = response[:header_end].decode("utf-8", errors="replace")

            is_chunked = False
            content_length = None
            for line in headers_raw.split("\r\n"):
                low = line.lower()
                if low.startswith("transfer-encoding:"):
                    if "chunked" in low:
                        is_chunked = True
                elif low.startswith("content-length:"):
                    content_length = int(line.split(":")[1].strip())

            body_resp = response[header_end:]

            if is_chunked:
                while not body_resp.endswith(b"0\r\n\r\n"):
                    try:
                        chunk = remote_ssl.recv(65536)
                        if not chunk:
                            break
                        body_resp += chunk
                    except socket.timeout:
                        break
                response = headers_raw.encode() + body_resp
            elif content_length is not None:
                remaining = content_length - len(body_resp)
                while remaining > 0:
                    try:
                        chunk = remote_ssl.recv(min(65536, remaining))
                        if not chunk:
                            break
                        response += chunk
                        remaining -= len(chunk)
                    except socket.timeout:
                        break
            else:
                try:
                    while True:
                        chunk = remote_ssl.recv(65536)
                        if not chunk:
                            break
                        response += chunk
                except socket.timeout:
                    pass

        except socket.timeout:
            log(f"Upstream timeout after receiving {len(response)} bytes")

        client_sock.sendall(response)
        remote_ssl.close()
    except Exception as e:
        log(f"Forward error: {e}")
        error_resp = json_response({"error": str(e)}, "502 Bad Gateway")
        client_sock.sendall(error_resp)

    client_sock.close()


def get_real_key():
    """Get the real TokenRouter API key from env, keyfile, or secret-cache."""
    key = os.environ.get("TOKENROUTER_API_KEY")
    if key:
        return key
    if os.path.exists(KEYFILE):
        try:
            with open(KEYFILE) as f:
                return f.read().strip()
        except Exception:
            pass
    import subprocess
    try:
        result = subprocess.run(
            ["secret-cache", "exec", "--", "bash", "-c", "echo $TOKENROUTER_API_KEY"],
            capture_output=True, text=True, timeout=5
        )
        key = result.stdout.strip()
        if key:
            return key
    except Exception:
        pass
    return None


# ─── Server ────────────────────────────────────────────────────────────────

def run_server():
    real_key = get_real_key()
    if not real_key:
        print("ERROR: TOKENROUTER_API_KEY not found", file=sys.stderr)
        sys.exit(1)

    # Start background quota refresher
    refresh_thread = threading.Thread(target=quota_refresh_loop, daemon=True)
    refresh_thread.start()
    log(f"Starting on port {PORT} → {UPSTREAM[0]}:{UPSTREAM[1]} (with routing)")

    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    sock.bind(("127.0.0.1", PORT))
    sock.listen(128)
    sock.settimeout(1.0)

    running = True

    def shutdown(s, f):
        nonlocal running
        log("Shutting down")
        running = False

    signal.signal(signal.SIGINT, shutdown)
    signal.signal(signal.SIGTERM, shutdown)

    while running:
        try:
            client, addr = sock.accept()
            threading.Thread(target=handle_client, args=(client,), daemon=True).start()
        except socket.timeout:
            continue
        except Exception as e:
            log(f"Accept error: {e}")

    sock.close()
    log("Stopped")


def daemonize():
    key = get_real_key()
    if not key:
        print("ERROR: TOKENROUTER_API_KEY not found", file=sys.stderr)
        sys.exit(1)

    pid = os.fork()
    if pid > 0:
        print(f"routing-proxy started (pid {pid})", file=sys.stderr)
        sys.exit(0)

    os.setsid()
    pid2 = os.fork()
    if pid2 > 0:
        sys.exit(0)

    os.makedirs(os.path.dirname(PIDFILE), exist_ok=True)
    with open(PIDFILE, "w") as f:
        f.write(str(os.getpid()))

    with open(KEYFILE, "w") as f:
        f.write(key)

    os.makedirs(os.path.dirname(LOGFILE), exist_ok=True)
    sys.stdout = open(LOGFILE, "a")
    sys.stderr = open(LOGFILE, "a")

    run_server()


def stop():
    if os.path.exists(PIDFILE):
        with open(PIDFILE) as f:
            pid = int(f.read().strip())
        try:
            os.kill(pid, signal.SIGTERM)
            print(f"routing-proxy (pid {pid}) stopped", file=sys.stderr)
        except ProcessLookupError:
            print("routing-proxy not running", file=sys.stderr)
        os.unlink(PIDFILE)
    if os.path.exists(KEYFILE):
        os.unlink(KEYFILE)


def status():
    if os.path.exists(PIDFILE):
        with open(PIDFILE) as f:
            pid = int(f.read().strip())
        try:
            os.kill(pid, 0)
            print(f"routing-proxy running (pid {pid})", file=sys.stderr)
            return True
        except ProcessLookupError:
            print("routing-proxy stale PID", file=sys.stderr)
            os.unlink(PIDFILE)
    print("routing-proxy not running", file=sys.stderr)
    return False


if __name__ == "__main__":
    if len(sys.argv) > 1:
        cmd = sys.argv[1]
        if cmd == "--daemon":
            daemonize()
        elif cmd == "--stop":
            stop()
        elif cmd == "--status":
            status()
        else:
            print(__doc__, file=sys.stderr)
            sys.exit(1)
    else:
        run_server()
