#!/usr/bin/env bash
# bridge-ca: bridge wrapper for the ca (direct Anthropic) adapter.
# Runs Claude Code in print mode (non-interactive, exits when done),
# then produces the manifest.json that bridge's verifier expects.
#
# Reads brief.md from the current directory (the worktree).
# Spawn.go launches this as a bare command via mintmux — no shell wrapping.
set -euo pipefail

# mintmux sessions don't source shell profiles. Bootstrap the environment
# so that ca and npx are reachable.
export HOME="${HOME:-/Users/jwalinshah}"
export PATH="$HOME/bin:$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
export USER="${USER:-jwalinshah}"

echo "=== bridge-ca: starting (PATH=$PATH) ===" >&2

# Touch a heartbeat file immediately AND in a background loop so that
# bridge's staleness detection (which watches worktree file mtimes) knows
# this adapter is alive even while npx/claude-code is starting up
# (which can take 30-90s from cold).
touch .bridge-ca-heartbeat
while true; do
  sleep 10
  touch .bridge-ca-heartbeat
done &
HEARTBEAT_PID=$!
trap 'kill $HEARTBEAT_PID 2>/dev/null; exit' EXIT INT TERM

# Read the brief from the worktree (copied there by spawn.go).
BRIEF=$(cat brief.md)

# Run Claude Code in print mode with the brief as the prompt.
# Use absolute paths — mintmux sessions don't have ~/bin on PATH.
/Users/jwalinshah/bin/ca -p --dangerously-skip-permissions "$BRIEF"
# Heartbeat loop is killed by the trap on exit.

echo "=== bridge-ca: Claude Code finished, capturing state ===" >&2

TICKET_ID="unknown"
if [ -f ticket.json ]; then
  TICKET_ID=$(jq -r .id ticket.json 2>/dev/null || echo "unknown")
fi

# Commit any changes (including untracked files) so they're captured in the tree SHA.
if [ -n "$(git status --porcelain)" ]; then
  echo "=== bridge-ca: committing changes ===" >&2
  git add -A
  git commit -m "bridge: auto-commit for ticket $TICKET_ID" || true
fi

TREE_SHA=$(git rev-parse HEAD^{tree})
BRANCH=$(git rev-parse --abbrev-ref HEAD)

echo "=== bridge-ca: tree_sha=$TREE_SHA ===" >&2

# Build file_exists assertions for files changed in the last commit.
# We don't add verification_command assertions — the verifier already
# independently re-runs the ticket's verification_commands.
ASSERTIONS="[]"
CHANGED_FILES=$(git diff --name-only HEAD~1 2>/dev/null || echo "")
for f in $CHANGED_FILES; do
  ASSERTIONS=$(echo "$ASSERTIONS" | jq -r ". + [{\"type\": \"file_exists\", \"text\": \"$f\"}]")
done

cat > manifest.json << MANIFEST
{
  "run_id": "bridge-ca-$(date +%s)",
  "ticket": "$TICKET_ID",
  "agent": "claude-code/ca",
  "branch": "$BRANCH",
  "tree_sha": "$TREE_SHA",
  "assertions": $ASSERTIONS,
  "observations": ["work completed by Claude Code via bridge-ca"]
}
MANIFEST

echo "=== bridge-ca: manifest.json written, done ===" >&2
