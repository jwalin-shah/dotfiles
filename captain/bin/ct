#!/usr/bin/env bash
# Claude Code via TokenRouter (direct, no compression proxy overhead).
# Fast access to 105+ models aggregated through TokenRouter.
set -euo pipefail

# Use TokenRouter directly (no Headroom compression overhead)
# This is fast and reliable. Compression comes from hooks, not proxy.
PROFILE="token"

exec "$HOME/.local/bin/secret-cache" exec -- \
  "$HOME/bin/claude-launch" run "$PROFILE" --dangerously-skip-permissions "$@"
