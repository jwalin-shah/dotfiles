#!/usr/bin/env bash
# Claude Code via Headroom (compression proxy) -> TokenRouter gateway.
# Routes through headroom@8788 for context compression + token savings.
set -euo pipefail

check_headroom() {
  curl -sS -m 5 -o /dev/null -w "%{http_code}" \
    http://127.0.0.1:8788/health | grep -qx '200'
}

check_tokenrouter() {
  curl -sS -m 3 -o /dev/null -w "%{http_code}" \
    -X HEAD http://127.0.0.1:18999/v1/models | grep -qx '200'
}

if ! check_tokenrouter; then
  if [ -x "$HOME/bin/routing-proxy" ]; then
    "$HOME/bin/routing-proxy" --daemon >/dev/null 2>&1 || true
  else
    "$HOME/bin/tokenrouter-proxy" --daemon >/dev/null 2>&1 || true
  fi
  sleep 1
fi

check_tokenrouter || {
  echo "ct: TokenRouter proxy not running. Start it: routing-proxy --daemon" >&2
  exit 1
}

if ! check_headroom; then
  echo "ct: WARNING - Headroom not responding on :8788. Using direct TokenRouter fallback." >&2
  PROFILE="token"
else
  PROFILE="headroom"
fi

exec "$HOME/.local/bin/secret-cache" exec -- \
  "$HOME/bin/claude-launch" run "$PROFILE" --dangerously-skip-permissions "$@"
