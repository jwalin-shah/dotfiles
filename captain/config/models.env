# ~/.config/jw/models.env — Single source of truth for local AI model config.
# Edit ONLY this file to switch models across the entire jw toolchain.
# Sourced by: ~/bin/start-mlx-server.sh (LaunchAgent wrapper), ~/bin/cognee,
#   ~/bin/start-cognee-mcp, ~/bin/resume-data-exports-ingest.sh

# ── Chat / Completion model (served on :8080) ────────────────────────────────
JW_CHAT_MODEL_REPO="LiquidAI/LFM2.5-8B-A1B-MLX-4bit"
JW_CHAT_MODEL="openai/${JW_CHAT_MODEL_REPO}"
JW_CHAT_MODEL_PATH="/Users/jwalinshah/.cache/huggingface/hub/models--LiquidAI--LFM2.5-8B-A1B-MLX-4bit/snapshots/760bf10c9e91d8330a554ae144fdb2bcd597b0c2"
JW_CHAT_MAX_TOKENS=8192

# ── Embedding model (served on :8081) ────────────────────────────────────────
JW_EMBED_MODEL_REPO="mlx-community/Qwen3-Embedding-0.6B-4bit-DWQ"
JW_EMBED_MODEL_PATH="/Users/jwalinshah/.cache/huggingface/hub/models--mlx-community--Qwen3-Embedding-0.6B-4bit-DWQ/snapshots/6c3ae70858513f1a78e9cdca3cae330d9075cd2a"
JW_EMBED_DIMENSIONS=1024

# ── Export for subprocesses ───────────────────────────────────────────────────
export JW_CHAT_MODEL JW_CHAT_MODEL_REPO JW_CHAT_MODEL_PATH JW_CHAT_MAX_TOKENS
export JW_EMBED_MODEL_REPO JW_EMBED_MODEL_PATH JW_EMBED_DIMENSIONS

# Cognee/litellm env vars
export LLM_PROVIDER=openai
export LLM_MODEL="${JW_CHAT_MODEL}"
export LLM_ENDPOINT="http://localhost:8080/v1"
export LLM_API_KEY=sk-local
export LLM_TEMPERATURE=0.0
export LLM_MAX_TOKENS="${JW_CHAT_MAX_TOKENS}"
export LLM_MAX_COMPLETION_TOKENS="${JW_CHAT_MAX_TOKENS}"
export LLM_INSTRUCTOR_MODE=markdown_json_mode

export EMBEDDING_PROVIDER=openai_compatible
export EMBEDDING_ENDPOINT="http://127.0.0.1:8081/v1"
export EMBEDDING_MODEL="mlx-community/Qwen3-Embedding-0.6B-4bit-DWQ"
export EMBEDDING_DIMENSIONS="${JW_EMBED_DIMENSIONS}"
export EMBEDDING_MAX_COMPLETION_TOKENS=512

export COGNEE_SKIP_CONNECTION_TEST=true
export CACHING=true
