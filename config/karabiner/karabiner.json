{
  "profiles": [
    {
      "complex_modifications": {
        "rules": [
          {
            "description": "Caps Lock + Space = tmux prefix (Ctrl-b)",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "spacebar",
                  "modifiers": {
                    "mandatory": [
                      "caps_lock"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "b",
                    "modifiers": [
                      "left_control"
                    ]
                  }
                ]
              }
            ]
          },
          {
            "description": "Caps Lock to Left Option (so all alt-* binds are on Caps Lock)",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "caps_lock",
                  "modifiers": {
                    "optional": [
                      "any"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "left_option"
                  }
                ]
              }
            ]
          },
          {
            "description": "Right Command: tap = toggle voice, hold = normal command",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "right_command"
                },
                "to": [
                  {
                    "key_code": "right_command"
                  }
                ],
                "to_if_alone": [
                  {
                    "shell_command": "~/.local/bin/voice-toggle"
                  }
                ],
                "parameters": {
                  "basic.to_if_alone_timeout_milliseconds": 150
                }
              }
            ]
          },
          {
            "description": "Left Option + P = PiP (Cmd-Shift-9)",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "p",
                  "modifiers": {
                    "mandatory": [
                      "left_option"
                    ]
                  }
                },
                "to": [
                  {
                    "key_code": "9",
                    "modifiers": [
                      "left_command",
                      "left_shift"
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      "fn_function_keys": [
        {
          "from": {
            "key_code": "f3"
          },
          "to": [
            {
              "key_code": "mission_control"
            }
          ]
        },
        {
          "from": {
            "key_code": "f4"
          },
          "to": [
            {
              "key_code": "launchpad"
            }
          ]
        },
        {
          "from": {
            "key_code": "f5"
          },
          "to": [
            {
              "key_code": "illumination_decrement"
            }
          ]
        },
        {
          "from": {
            "key_code": "f6"
          },
          "to": [
            {
              "key_code": "illumination_increment"
            }
          ]
        },
        {
          "from": {
            "key_code": "f9"
          },
          "to": [
            {
              "consumer_key_code": "fastforward"
            }
          ]
        }
      ],
      "name": "Orbit",
      "selected": true,
      "virtual_hid_keyboard": {
        "country_code": 0,
        "keyboard_type_v2": "ansi"
      }
    }
  ]
}