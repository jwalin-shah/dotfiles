# ~/.config/orbit/models.env — Single source of truth for local AI models.
# Edit ONLY this file to switch models across all LaunchAgents.
# Sourced by: daemon-wrapper (via DAEMON_ENV_FILE), bridge pipelines.

# ── Chat model (served on :8080 via mlx-chat-daemon) ──────────────────────────
ORBIT_CHAT_MODEL_REPO="mlx-community/Qwen3.5-9B-OptiQ-4bit"
ORBIT_CHAT_MODEL="openai/${ORBIT_CHAT_MODEL_REPO}"
ORBIT_CHAT_MAX_TOKENS=8192

# ── Embedding model (served on :8081 via llama-embed-server) ──────────────────
ORBIT_EMBED_MODEL_PATH="/Users/jwalinshah/.cache/huggingface/hub/models--Qwen--Qwen3-Embedding-0.6B-GGUF/snapshots/main/Qwen3-Embedding-0.6B-Q8_0.gguf"
ORBIT_EMBED_DIMENSIONS=1024

# ── Code embedding model (served on :8082 via coderank-embed-server) ───────────
ORBIT_CODERANK_MODEL_PATH="/Users/jwalinshah/.cache/huggingface/hub/models--handwoven8588--CodeRankEmbed-GGUF/snapshots/14be4104a35a5f4e32e6e225955ccf271fb5b956/CodeRankEmbed-Q8_0.gguf"

# ── Pipeline LLM (TokenRouter) — structured extraction via bridge ────────────
# API key injected at runtime from Keychain, never on disk.
PIPELINE_LLM_MODEL="deepseek/deepseek-v4-flash"
PIPELINE_LLM_BASE_URL="https://api.tokenrouter.com/v1"

# ── Export ────────────────────────────────────────────────────────────────────
export ORBIT_CHAT_MODEL_REPO ORBIT_CHAT_MODEL ORBIT_CHAT_MAX_TOKENS
export ORBIT_EMBED_MODEL_PATH ORBIT_EMBED_DIMENSIONS
export ORBIT_CODERANK_MODEL_PATH
export PIPELINE_LLM_MODEL PIPELINE_LLM_BASE_URL
