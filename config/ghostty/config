# Ghostty - daily driver terminal config.

font-family = "JetBrains Mono"
font-size = 14
font-thicken = true
font-thicken-strength = 80
adjust-cell-height = 8%

theme = "TokyoNight Storm"
background-opacity = 0.94
background-blur = true

cursor-style = bar
cursor-style-blink = true
cursor-opacity = 0.95

window-padding-x = 10
window-padding-y = 8
window-padding-balance = true
window-padding-color = background
window-decoration = true
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden

unfocused-split-opacity = 0.82
split-divider-color = #3b4261

mouse-hide-while-typing = true
copy-on-select = false
confirm-close-surface = false
shell-integration = zsh
shell-integration-features = cursor,no-sudo,title,no-ssh-env,no-ssh-terminfo,path
clipboard-read = allow
clipboard-write = allow

# Make Option work as Alt for terminal tools.
macos-option-as-alt = true

# Keep new sessions inside one Aerospace-managed window by default.
keybind = super+n=new_tab

# Splits and navigation.
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+alt+arrow_left=goto_split:left
keybind = super+alt+arrow_right=goto_split:right
keybind = super+alt+arrow_up=goto_split:up
keybind = super+alt+arrow_down=goto_split:down
keybind = super+ctrl+arrow_left=resize_split:left,10
keybind = super+ctrl+arrow_right=resize_split:right,10
keybind = super+ctrl+arrow_up=resize_split:up,10
keybind = super+ctrl+arrow_down=resize_split:down,10
keybind = super+ctrl+==equalize_splits

# Config and command surface.
keybind = super+shift+,=reload_config
keybind = super+shift+p=toggle_command_palette
keybind = super+shift+enter=toggle_split_zoom
keybind = super+`=toggle_quick_terminal
