{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "deny": [],
    "ask": [
      "Bash(rm *)",
      "Bash(rm -r *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fdx *)",
      "Bash(git checkout -- .)",
      "Bash(git switch --discard-changes *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(launchctl *)",
      "Bash(brew *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(sudo *)",
      "Bash(chown *)",
      "Bash(chmod 777 *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)"
    ]
  },
  "model": "haiku",
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); if [ -n \"$used\" ]; then printf \"%s | ctx: %.0f%% used\" \"$model\" \"$used\"; else printf \"%s\" \"$model\"; fi"
  },
  "enabledPlugins": {
    "headroom@headroom-marketplace": true
  },
  "extraKnownMarketplaces": {
    "headroom-marketplace": {
      "source": {
        "source": "github",
        "repo": "chopratejas/headroom"
      }
    }
  },
  "skipDangerousModePermissionPrompt": false,
  "theme": "dark-ansi",
  "verbose": false,
  "agentPushNotifEnabled": true,
  "_comment": "DO NOT add ANTHROPIC_BASE_URL here. OAuth sends no API key, so Headroom rejects it. Add profiles in claude-endpoints.toml instead."
}
