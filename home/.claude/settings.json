{
  "_comment": "DO NOT add ANTHROPIC_BASE_URL here. OAuth sends no API key, so Headroom rejects it. Add profiles in claude-endpoints.toml instead.",
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "ask": [
      "Bash(brew uninstall)",
      "Bash(brew uninstall:*)",
      "Bash(brew)",
      "Bash(brew:*)",
      "Bash(chmod 777)",
      "Bash(chmod 777:*)",
      "Bash(chown)",
      "Bash(chown:*)",
      "Bash(git clean)",
      "Bash(git clean:*)",
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git reset)",
      "Bash(git reset:*)",
      "Bash(launchctl)",
      "Bash(launchctl:*)",
      "Bash(npm)",
      "Bash(npm:*)",
      "Bash(pnpm)",
      "Bash(pnpm:*)"
    ],
    "allow": [
      "Bash(bun)",
      "Bash(bun:*)",
      "Bash(ccc)",
      "Bash(ccc:*)",
      "Bash(chrome-devtools-axi)",
      "Bash(chrome-devtools-axi:*)",
      "Bash(cocoindex-code)",
      "Bash(cocoindex-code:*)",
      "Bash(cognee-cli)",
      "Bash(cognee-cli:*)",
      "Bash(ctx7)",
      "Bash(ctx7:*)",
      "Bash(du -s)",
      "Bash(du -s:*)",
      "Bash(du -sh)",
      "Bash(du -sh:*)",
      "Bash(fastedit)",
      "Bash(fastedit:*)",
      "Bash(gh-axi)",
      "Bash(gh-axi:*)",
      "Bash(githits)",
      "Bash(githits:*)",
      "Bash(gtimeout)",
      "Bash(gtimeout:*)",
      "Bash(inf)",
      "Bash(inf:*)",
      "Bash(jq)",
      "Bash(jq:*)",
      "Bash(lavish-axi)",
      "Bash(lavish-axi:*)",
      "Bash(llm-tldr)",
      "Bash(llm-tldr:*)",
      "Bash(pioneer)",
      "Bash(pioneer:*)",
      "Bash(rtk)",
      "Bash(rtk:*)",
      "Bash(secret-cache exec)",
      "Bash(secret-cache exec:*)",
      "Bash(timeout)",
      "Bash(timeout:*)",
      "Bash(treehouse)",
      "Bash(treehouse:*)",
      "Bash(uv)",
      "Bash(uv:*)",
      "Bash(yq)",
      "Bash(yq:*)"
    ],
    "deny": [
      "Bash(rm)",
      "Bash(rm:*)",
      "Bash(security)",
      "Bash(security:*)",
      "Bash(sudo)",
      "Bash(sudo:*)",
      "Bash(export)",
      "Bash(export:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jwalinshah/bin/jw-squeeze-hook.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jwalinshah/bin/headroom-bridge-hook.sh ensure",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jwalinshah/bin/headroom-bridge-hook.sh post",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "headroom@headroom-marketplace": true
  },
  "extraKnownMarketplaces": {
    "headroom-marketplace": {
      "source": {
        "source": "github",
        "repo": "chopratejas/headroom"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); if [ -n \"$used\" ]; then printf \"%s | ctx: %.0f%% used\" \"$model\" \"$used\"; else printf \"%s\" \"$model\"; fi"
  },
  "verbose": false
}
