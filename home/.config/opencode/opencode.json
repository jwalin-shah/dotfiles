{
  "$schema": "https://opencode.ai/config.json",
  "model": "tokenrouter/deepseek/deepseek-v4-flash",
  "small_model": "tokenrouter/deepseek/deepseek-v4-flash",

  "provider": {
    "tokenrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "TokenRouter",
      "options": {
        "baseURL": "https://api.tokenrouter.com/v1",
        "apiKey": "{env:TOKENROUTER_API_KEY}"
      },
      "models": {
        "anthropic/claude-opus-4.8": { "name": "Claude Opus 4.8" },
        "anthropic/claude-sonnet-4.6": { "name": "Claude Sonnet 4.6" },
        "anthropic/claude-haiku-4.5": { "name": "Claude Haiku 4.5" },
        "deepseek/deepseek-v4-pro": { "name": "DeepSeek V4 Pro" },
        "deepseek/deepseek-v4-flash": { "name": "DeepSeek V4 Flash" },
        "qwen/qwen3.7-max": { "name": "Qwen 3.7 Max" },
        "openai/gpt-5.5": { "name": "GPT 5.5" }
      }
    }
  },

  "permission": {
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "allow",
      "rm": "ask",
      "rm *": "ask",
      "sudo": "ask",
      "sudo *": "ask"
    }
  },

  "shell": "zsh",
  "lsp": false
}
