{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "tokenrouter/deepseek/deepseek-v4-flash",
  "small_model": "tokenrouter/deepseek/deepseek-v4-flash",
  "indexing": {
    "enabled": false,
    "provider": "openai-compatible",
    "model": "CodeRankEmbed",
    "dimension": 768,
    "vectorStore": "lancedb",
    "openai-compatible": {
      "baseUrl": "http://127.0.0.1:8082/v1",
      "apiKey": "local"
    },
    "lancedb": {},
    "searchMinScore": 0.35,
    "searchMaxResults": 50,
    "embeddingBatchSize": 32,
    "scannerMaxBatchRetries": 3
  },
  "provider": {
    "tokenrouter": {
      "options": {
        "apiKey": "{env:TOKENROUTER_API_KEY}",
