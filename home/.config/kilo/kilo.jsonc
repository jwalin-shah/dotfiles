  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "semantic_search": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "skill": "allow",
    "question": "allow",
    "external_directory": "allow",
    "bash": {
      "*": "allow",
      "rm": "ask",
      "rm *": "ask",
      "git reset --hard": "ask",
      "git reset --hard *": "ask",
      "git clean -fd": "ask",
      "git clean -fd *": "ask",
      "git clean -fdx": "ask",
      "git clean -fdx *": "ask",
      "git checkout -- .": "ask",
      "git switch --discard-changes": "ask",
      "git switch --discard-changes *": "ask",
      "git push --force": "ask",
      "git push --force *": "ask",
      "git push -f": "ask",
      "git push -f *": "ask",
      "sudo": "ask",
      "sudo *": "ask",
      "dd": "ask",
      "dd *": "ask",
      "mkfs": "ask",
      "mkfs*": "ask"
    }
  },
  "instructions": ["~/.config/kilo/instructions/*.md"]
}
