prefix_rule(pattern=["/bin/zsh", "-lc", "ps axww -o pid=,ppid=,lstart=,etime=,stat=,command= | rg -i 'firstmate|fm-|mintmux|mm-event|watchdog|watcher|wake|pipeline|no-mistakes|treehouse|codex|claude|opencode|cursor-agent|agy' || true; tmux list-sessions 2>&1; tmux list-windows -a -F '#{session_name}\\t#{window_index}\\t#{window_name}\\t#{window_active}\\t#{window_panes}\\t#{window_activity}\\t#{window_flags}' 2>&1; mm-ctl ping 2>&1; mm-ctl list-panes 2>&1"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "pgrep -alf 'fm-watch|fm-watchdog|mm-event-sub|events.jsonl|fm-supervise|fm-subsuper|fm-stage-enforce|no-mistakes|treehouse get|mintmux' || true; ps -axo pid=,ppid=,etime=,state=,comm= | rg -i 'mintmux|tmux|claude|codex|no-mistakes|treehouse|bash|zsh' || true; lsof -n -P -p 13867 2>&1 | sed -n '1,220p'; mm-ctl list-panes --help 2>&1; eza -la /private/tmp | rg -i 'mint|mux|tmux' || true"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "for f in state/.lock state/fm-fix-symlink-loop.meta state/fm-fix-symlink-loop.status state/tmux-edge-cases.meta state/tmux-edge-cases.status; do echo \"FILE $f\"; nl -ba \"$f\"; done; stat -f '%N|mtime=%m|%Sm|size=%z' -t '%Y-%m-%d %H:%M:%S %Z' state/.last-watcher-beat state/.wake-queue state/.watch-triage.log state/.lock; lockpid=$(tr -d '[:space:]' < state/.lock); ps -p \"$lockpid\" -o pid=,ppid=,lstart=,etime=,stat=,command= 2>&1; echo 'PANE tmux-edge-cases'; tmux capture-pane -p -S -120 -t 0:2 2>&1; echo 'PANE symlink-loop'; tmux capture-pane -p -S -120 -t 0:4 2>&1; echo 'TRIAGE'; tail -80 state/.watch-triage.log"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "treehouse status 2>&1; tmux list-panes -a -F '#{session_name}:#{window_name}\\tpid=#{pane_pid}\\tdead=#{pane_dead}\\tactivity=#{window_activity}\\tcwd=#{pane_current_path}\\tcmd=#{pane_current_command}' 2>&1; for d in /Users/jwalinshah/projects/firstmate /Users/jwalinshah/.treehouse/firstmate-4010f5/{2,4,10,11,12,13,14,15,16}/firstmate /Users/jwalinshah/secondmates/2nd-{btw,infra,life,voice}; do if [ -e \"$d\" ]; then echo \"DIR $d\"; git -C \"$d\" status --short --branch 2>&1; git -C \"$d\" log -1 --oneline 2>&1; else echo \"MISSING $d\"; fi; done"], decision="allow")
prefix_rule(pattern=["ps", "axww", "-o", "pid=,ppid=,lstart=,etime=,stat=,command="], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "mm-ctl list-panes -session 0 2>&1; mm-ctl list-panes -session firstmate 2>&1; mm-ctl list-panes -session default 2>&1"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "treehouse status 2>&1; ps -p 54478 -o pid=,ppid=,lstart=,etime=,stat=,comm= 2>&1; lsof -a -p 54478 -d cwd -Fn 2>&1; if [ -d /Users/jwalinshah/.treehouse/firstmate-4010f5/9/firstmate ]; then git -C /Users/jwalinshah/.treehouse/firstmate-4010f5/9/firstmate status --short --branch; git -C /Users/jwalinshah/.treehouse/firstmate-4010f5/9/firstmate log -1 --oneline; fi"], decision="allow")
prefix_rule(pattern=["ps", "-p"], decision="allow")
