prefix_rule(pattern=["/bin/zsh", "-lc", "mkdir -p \"$HOME/.local/share/jw\" && nohup gnhf --worktree --agent codex --prevent-sleep on --max-iterations 8 \"Objective: audit and clean up the inbox control-plane repo in a separate worktree. Reconcile the top-level docs and plan files with the current code and service layout, identify stale or contradictory system references, and make only low-risk, high-confidence cleanup changes. Preserve user changes. Do not touch CHANGELOG.md or generated artifacts. Favor documentation and small correctness fixes over broad refactors. Verify any code or doc change with the smallest relevant checks. Stop only when the cleanup plan is written, the highest-confidence inconsistencies are fixed, and the remaining gaps are clearly documented.\" > \"$HOME/.local/share/jw/gnhf-inbox.log\" 2>&1 & echo $!"], decision="allow")
