{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jwalinshah/projects/dotfiles/bin/fmt-on-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash|edit_file",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/jwalinshah/.dotfiles/bin/enforce-bridge-workflow.sh"
          }
        ]
      }
    ]
  },
  "context": {
    "fileName": [
      "CONTEXT.md",
      "GEMINI.md",
      "AGENTS.md"
    ]
  }
}
